# Xcode — generated by XcodeGen from project.yml
# Ignore the whole xcodeproj EXCEPT the shared scheme XML, which Xcode Cloud
# scans at workflow-configure time. XcodeGen produces it deterministically.
*.xcodeproj/*
!*.xcodeproj/xcshareddata
*.xcodeproj/xcshareddata/*
!*.xcodeproj/xcshareddata/xcschemes
*.xcuserstate
*.xcuserdatad/
DerivedData/
.mutation-derived/
.mutation-derived-mac/
Packages/*/.build/
*.mut.bak
build/
*.ipa
*.dSYM.zip
*.dSYM
*.xcresult
.coverage.xcresult/

# Secrets - NEVER commit
Secrets.xcconfig
**/Secrets.swift

# macOS
.DS_Store

# Claude Code local config (per-user)
.claude/
