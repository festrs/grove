# Xcode — generated by XcodeGen from project.yml
# Ignore the whole xcodeproj EXCEPT:
#   - shared scheme XML (Xcode Cloud scans schemes from the repo)
#   - Package.resolved (Xcode Cloud requires it for SPM resolution)
*.xcodeproj/*
!*.xcodeproj/xcshareddata
*.xcodeproj/xcshareddata/*
!*.xcodeproj/xcshareddata/xcschemes
!*.xcodeproj/project.xcworkspace
*.xcodeproj/project.xcworkspace/*
!*.xcodeproj/project.xcworkspace/xcshareddata
*.xcodeproj/project.xcworkspace/xcshareddata/*
!*.xcodeproj/project.xcworkspace/xcshareddata/swiftpm
*.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/*
!*.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/Package.resolved
*.xcuserstate
*.xcuserdatad/
DerivedData/
.mutation-derived/
.mutation-derived-mac/
Packages/*/.build/
*.mut.bak
build/
*.ipa
*.dSYM.zip
*.dSYM
*.xcresult
.coverage.xcresult/

# Secrets — Secrets.xcconfig holds the actual key values and never goes
# to git. Grove/Secrets.swift is committed and reads from Info.plist at
# runtime, so the build can produce a working binary on CI from xcconfig
# alone.
Secrets.xcconfig

# macOS
.DS_Store

# Claude Code local config (per-user)
.claude/
