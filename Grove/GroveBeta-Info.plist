<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Partial Info.plist merged with the auto-generated entries from
  INFOPLIST_KEY_* build settings (Xcode merges this file with the
  generated plist when GENERATE_INFOPLIST_FILE=YES). Only carries the
  ATS exception that lets the simulator/device hit the local Docker
  backend over plain HTTP. Production (Grove target) doesn't use this
  file and stays ATS-strict.
-->
<plist version="1.0">
<dict>
    <key>MOBILE_API_KEY</key>
    <string>$(MOBILE_API_KEY)</string>
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSExceptionDomains</key>
        <dict>
            <key>localhost</key>
            <dict>
                <key>NSExceptionAllowsInsecureHTTPLoads</key>
                <true/>
                <key>NSIncludesSubdomains</key>
                <true/>
            </dict>
        </dict>
    </dict>
</dict>
</plist>
