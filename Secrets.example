// Copy this file to `Secrets.xcconfig` (sibling of `project.yml`) and fill
// in your values. `Secrets.xcconfig` is git-ignored and never committed.
// Xcode pipes these into the Info.plist at build time; `Grove/Secrets.swift`
// reads them at runtime via `Bundle.main`.

BRAPI_TOKEN = YOUR_BRAPI_TOKEN_HERE
MOBILE_API_KEY = YOUR_MOBILE_API_KEY_HERE
